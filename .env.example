# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
# .env.example is committed — it documents what variables are needed
# without exposing actual values.

APP_ENV=development

DB_NAME=linkly
DB_USER=linkly
DB_PASS=changeme

POSTGRES_DB=linkly
POSTGRES_USER=linkly
POSTGRES_PASSWORD=changeme

REDIS_HOST=redis
REDIS_PORT=6379
